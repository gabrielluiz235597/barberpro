  { id:'b03', cat:'barba', emoji:'🔽', name:'Barba Degradê', time:35, price:'R$ 50', popular:false },
  { id:'b04', cat:'barba', emoji:'🔥', name:'Barba + Toalha Quente', time:40, price:'R$ 60', popular:false },
  { id:'b05', cat:'barba', emoji:'🎨', name:'Pigmentação de Barba', time:45, price:'R$ 70', popular:false },
  // ESPECIAIS
  { id:'e01', cat:'especial', emoji:'👁️', name:'Sobrancelha', time:15, price:'R$ 25', popular:false },
  { id:'e02', cat:'especial', emoji:'🎨', name:'Pigmentação Capilar', time:60, price:'R$ 90', popular:false },
  { id:'e03', cat:'especial', emoji:'💧', name:'Hidratação Capilar', time:40, price:'R$ 70', popular:false },
  { id:'e04', cat:'especial', emoji:'✨', name:'Luzes / Descoloração', time:90, price:'R$ 150+', popular:false },
  { id:'e05', cat:'especial', emoji:'💈', name:'Progressiva Masculina', time:90, price:'R$ 130', popular:false },
  { id:'e06', cat:'especial', emoji:'💫', name:'Selagem', time:70, price:'R$ 100', popular:false },
  { id:'e07', cat:'especial', emoji:'🌿', name:'Limpeza de Pele', time:30, price:'R$ 55', popular:false },
  // COMBOS
  { id:'c01', cat:'combo', emoji:'🎯', name:'Corte + Barba', time:70, price:'R$ 80', popular:true },
  { id:'c02', cat:'combo', emoji:'👑', name:'Combo Premium', time:90, price:'R$ 110', popular:false },
  { id:'c03', cat:'combo', emoji:'💎', name:'Corte + Barba + Sobrancelha', time:85, price:'R$ 100', popular:false },

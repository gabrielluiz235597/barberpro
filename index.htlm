const styles = [
  { emoji:'🔥', name:'Moderno', desc:'Tendência atual' },
  { emoji:'🏆', name:'Clássico', desc:'Atemporal e elegante' },
  { emoji:'⚡', name:'Street', desc:'Urbano e ousado' },
  { emoji:'🌊', name:'Natural', desc:'Despojado e livre' },
];

const TIMES = ['08:00','08:30','09:00','09:30','10:00','10:30','11:00','11:30',
               '13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30',
               '17:00','17:30','18:00','18:30','19:00'];

// Simulated busy times per day-key
const busyMap = {};

// ── STATE ──
let state = {
  selectedService: null,
  selectedDate: null,
  selectedTime: null,
  selectedStyle: null,
  clientName: '',
  clientPhone: '',
  clientObs: '',
  currentScreen: 1,
  calYear: new Date().getFullYear(),
  calMonth: new Date().getMonth(),
};

// ══════════════════════════════════════════════════════
// SUPABASE CONFIG
// ══════════════════════════════════════════════════════
const SUPABASE_URL = 'https://wjcvrkmtzkndmghiqdvc.supabase.co';
const SUPABASE_KEY = 'sb_publishable_8xuGRpyCPQN-1o4DpBPwWw_U5KqwmWM';

async function sbFetch(path, options = {}) {
  const res = await fetch(SUPABASE_URL + '/rest/v1/' + path, {
    headers: {
      'apikey': SUPABASE_KEY,
      'Authorization': 'Bearer ' + SUPABASE_KEY,
      'Content-Type': 'application/json',
      'Prefer': options.prefer || 'return=representation',
      ...options.headers
    },
    ...options
  });
  if (!res.ok) {
    const err = await res.text();
    throw new Error(err);
  }
  const text = await res.text();
  return text ? JSON.parse(text) : [];
}

async function loadBookings() {
  try {
    const data = await sbFetch('agendamentos?select=*&order=created_at.desc');
    bookings = data.map(r => ({
      code: r.code,
      service: r.service,
      emoji: r.emoji,
      time: r.time,
      date: r.date,
      dateKey: r.date_key,
      dateObj: r.date_obj,
      name: r.name,
      phone: r.phone,
      style: r.style,
      obs: r.obs,
      price: r.price,
      duration: r.duration,
      done: r.done,
      createdAt: r.created_at,
      _id: r.id
    }));
  } catch(e) {
    console.error('Erro ao carregar agendamentos:', e);
    bookings = [];
  }
}

async function saveBooking(booking) {
  await sbFetch('agendamentos', {
    method: 'POST',
    prefer: 'return=minimal',
    body: JSON.stringify({
      code: booking.code,
      service: booking.service,
      emoji: booking.emoji,
      time: booking.time,
      date: booking.date,
      date_key: booking.dateKey,
      date_obj: booking.dateObj,
      name: booking.name,
      phone: booking.phone,
      style: booking.style,
      obs: booking.obs,
      price: booking.price,
      duration: String(booking.duration),
      done: false
    })
  });
}

async function markDoneSupabase(code) {
  await sbFetch('agendamentos?code=eq.' + code, {
    method: 'PATCH',
    prefer: 'return=minimal',
    body: JSON.stringify({ done: true })
  });
}

let bookings = [];

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
async function startApp() {
  document.getElementById('splash').classList.add('hide');
  setTimeout(async () => {
    document.getElementById('splash').style.display = 'none';
    document.getElementById('app').classList.add('visible');
    await loadBookings();
    renderServices('all');
    renderCalendar();
    renderStyles();
  }, 600);
}

// ══════════════════════════════════════════════════════
// SERVICES
// ══════════════════════════════════════════════════════
function renderServices(cat) {
  const grid = document.getElementById('servicesGrid');
  const filtered = cat === 'all' ? services : services.filter(s => s.cat === cat);
  grid.innerHTML = filtered.map(s => `
    <div class="service-card ${state.selectedService?.id === s.id ? 'selected' : ''}" 
         onclick="selectService('${s.id}')" id="sc_${s.id}">
      ${s.popular ? '<span class="badge">🔥 Top</span>' : ''}
      <span class="service-emoji">${s.emoji}</span>
      <div class="service-name">${s.name}</div>
      <div class="service-time">⏱ ${s.time} min</div>
      <div class="service-price">${s.price}</div>
    </div>
  `).join('');
}

function filterCategory(cat, btn) {
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  renderServices(cat);
}

function selectService(id) {
  state.selectedService = services.find(s => s.id === id);
  document.querySelectorAll('.service-card').forEach(c => c.classList.remove('selected'));
  const el = document.getElementById('sc_' + id);
  if (el) el.classList.add('selected');
  document.getElementById('btnNext1').disabled = false;
  showToast('✂️ ' + state.selectedService.name + ' selecionado!');
}

// ══════════════════════════════════════════════════════
// CALENDAR
// ══════════════════════════════════════════════════════
const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const DAYS_PT = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

function renderCalendar() {
  const { calYear, calMonth } = state;
  document.getElementById('calTitle').textContent = MONTHS_PT[calMonth] + ' ' + calYear;
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
  const today = new Date(); today.setHours(0,0,0,0);

  let html = '';
  for (let i = 0; i < firstDay; i++) html += '<div class="cal-day empty"></div>';
  for (let d = 1; d <= daysInMonth; d++) {
    const dt = new Date(calYear, calMonth, d);
    const isPast = dt < today;
    const isSunday = dt.getDay() === 0;
    const isToday = dt.toDateString() === today.toDateString();
    const isSelected = state.selectedDate && dt.toDateString() === state.selectedDate.toDateString();
    let cls = 'cal-day';
    if (isPast || isSunday) cls += ' past';
    if (isToday) cls += ' today';
    if (isSelected) cls += ' selected';
    const onClick = (isPast || isSunday) ? '' : `onclick="selectDate(${calYear},${calMonth},${d})"`;
    html += `<div class="${cls}" ${onClick}>${d}</div>`;
  }
  document.getElementById('calGrid').innerHTML = html;
}

function prevMonth() {
  if (state.calMonth === 0) { state.calMonth = 11; state.calYear--; }
  else state.calMonth--;
  renderCalendar();
}
function nextMonth() {
  if (state.calMonth === 11) { state.calMonth = 0; state.calYear++; }
  else state.calMonth++;
  renderCalendar();
}

function selectDate(y, m, d) {
  state.selectedDate = new Date(y, m, d);
  state.selectedTime = null;
  document.getElementById('btnNext2').disabled = true;
  renderCalendar();
  renderSlots();
}

function renderSlots() {
  const sec = document.getElementById('slotsSection');
  sec.style.display = 'block';
  const dateKey = state.selectedDate.toDateString();
  const dayBookings = bookings.filter(b => b.dateKey === dateKey).map(b => b.time);

  const label = state.selectedDate.toLocaleDateString('pt-BR', { weekday:'long', day:'numeric', month:'long' });
  document.getElementById('slotsLabel').textContent = '📅 ' + label;

  const html = TIMES.map(t => {
    const isBusy = dayBookings.includes(t);
    const isSel = state.selectedTime === t;
    return `<div class="time-slot ${isBusy ? 'busy' : ''} ${isSel ? 'selected' : ''}" 
      ${isBusy ? '' : `onclick="selectTime('${t}')"`}>${t}</div>`;
  }).join('');
  document.getElementById('slotsGrid').innerHTML = html;
}

function selectTime(t) {
  state.selectedTime = t;
  renderSlots();
  document.getElementById('btnNext2').disabled = false;
  showToast('⏰ Horário ' + t + ' selecionado!');
}

// ══════════════════════════════════════════════════════
// STYLES
// ══════════════════════════════════════════════════════
function renderStyles() {
  document.getElementById('stylesGrid').innerHTML = styles.map((s, i) => `
    <div class="style-card ${state.selectedStyle === s.name ? 'selected' : ''}" 
         onclick="selectStyle('${s.name}', this)" id="style_${i}">
      <div class="style-icon">${s.emoji}</div>
      <div>
        <div class="style-name">${s.name}</div>
        <div class="style-desc">${s.desc}</div>
      </div>
    </div>
  `).join('');
}

function selectStyle(name, el) {
  state.selectedStyle = name;
  document.querySelectorAll('.style-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}

// ══════════════════════════════════════════════════════
// FORM
// ══════════════════════════════════════════════════════
function maskPhone(input) {
  let v = input.value.replace(/\D/g,'');
  if (v.length > 11) v = v.slice(0,11);
  if (v.length > 6) v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
  else if (v.length > 2) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
  else if (v.length > 0) v = `(${v}`;
  input.value = v;
}

function checkForm3() {
  const name = document.getElementById('clientName').value.trim();
  const phone = document.getElementById('clientPhone').value.replace(/\D/g,'');
  document.getElementById('btnNext3').disabled = !(name.length >= 3 && phone.length >= 10);
  state.clientName = name;
  state.clientPhone = document.getElementById('clientPhone').value;
}

// ══════════════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════════════
function goToScreen(n) {
  const curr = state.currentScreen;
  // Hide all screens
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('dashboard').classList.remove('active');

  if (n === 4) fillConfirmation();
  document.getElementById('screen' + n).classList.add('active');

  // Update progress
  ['prog1','prog2','prog3','prog4'].forEach((id, i) => {
    const el = document.getElementById(id);
    el.classList.remove('active','done');
    if (i + 1 < n) el.classList.add('done');
    else if (i + 1 === n) el.classList.add('active');
  });

  document.getElementById('progressBar').style.display = 'flex';
  state.currentScreen = n;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function fillConfirmation() {
  const s = state.selectedService;
  const style = state.selectedStyle || 'Não informado';
  const dateStr = state.selectedDate.toLocaleDateString('pt-BR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
  state.clientObs = document.getElementById('clientObs').value;

  document.getElementById('confirmEmoji').textContent = s.emoji;
  document.getElementById('confirmService').textContent = s.name;
  document.getElementById('confirmStyle').textContent = 'Estilo: ' + style;
  document.getElementById('confirmDate').textContent = dateStr;
  document.getElementById('confirmTime').textContent = state.selectedTime;
  document.getElementById('confirmName').textContent = state.clientName;
  document.getElementById('confirmPhone').textContent = state.clientPhone;
  document.getElementById('confirmDuration').textContent = s.time + ' minutos';
  document.getElementById('confirmPrice').textContent = s.price;
}

// ══════════════════════════════════════════════════════
// FINALIZE
// ══════════════════════════════════════════════════════
async function finalizeBooking() {
  const code = 'BP' + Math.random().toString(36).substr(2,6).toUpperCase();
  const s = state.selectedService;
  const style = state.selectedStyle || 'Não informado';
  const dateStr = state.selectedDate.toLocaleDateString('pt-BR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });

  const booking = {
    code,
    service: s.name,
    emoji: s.emoji,
    time: state.selectedTime,
    date: dateStr,
    dateKey: state.selectedDate.toDateString(),
    dateObj: state.selectedDate.toISOString(),
    name: state.clientName,
    phone: state.clientPhone,
    style,
    obs: state.clientObs,
    price: s.price,
    duration: s.time,
    done: false,
    createdAt: new Date().toISOString(),
  };

  bookings.push(booking);
  try {
    await saveBooking(booking);
  } catch(e) {
    console.error('Erro ao salvar no Supabase:', e);
    showToast('⚠️ Agendamento salvo localmente. Verifique conexão.');
  }

  // Mensagem completa para o barbeiro
  const msgBarber = encodeURIComponent(
`✂️ *NOVO AGENDAMENTO — BarberPro*

🆔 Código: *${code}*
👤 Cliente: *${booking.name}*
📱 WhatsApp Cliente: ${booking.phone}
📅 Data: ${dateStr}
⏰ Horário: *${booking.time}*
✂️ Serviço: *${booking.service}*
🎨 Estilo: ${style}
⏱ Duração: ${booking.duration} min
💰 Valor: ${booking.price}
${booking.obs ? '📝 Obs: ' + booking.obs : ''}

_Agendado via BarberPro App_ 💈`
  );

  // Mensagem de confirmação para o cliente (link separado)
  const clientPhoneRaw = booking.phone.replace(/\D/g,'');
  const clientPhoneFull = clientPhoneRaw.length === 11 ? '55' + clientPhoneRaw : clientPhoneRaw;
  const msgClient = encodeURIComponent(
`✅ *Agendamento Confirmado — BarberPro!*

Olá, *${booking.name}*! Seu horário está confirmado. 💈

📅 *${dateStr}*
⏰ *${booking.time}*
✂️ *${booking.service}*
💰 *${booking.price}*
🆔 Cód: ${code}

Em caso de dúvidas ou cancelamento, entre em contato com antecedência. Até lá! 🙌`
  );

  // Link WA direto para o barbeiro (11999805125)
  const barberWALink = `https://wa.me/${BARBER_PHONE}?text=${msgBarber}`;
  // Link WA para o cliente (abre conversa com o número dele)
  const clientWALink = clientPhoneFull.length >= 12
    ? `https://wa.me/${clientPhoneFull}?text=${msgClient}`
    : null;

  // Show success screen
  document.getElementById('progressBar').style.display = 'none';
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screenSuccess').classList.add('active');
  document.getElementById('successCode').textContent = code;
  document.getElementById('successMsg').textContent =
    `Olá ${booking.name}! Seu agendamento para ${s.name} no dia ${dateStr} às ${state.selectedTime} está confirmado!`;

  // Botão principal → abre WhatsApp do barbeiro com resumo completo
  const waBtn = document.getElementById('waConfirmBtn');
  waBtn.href = barberWALink;
  waBtn.textContent = '📲 Enviar Confirmação ao Barbeiro';

  // Adiciona botão de confirmação para o cliente (se número válido)
  const existingClientBtn = document.getElementById('waClientBtn');
  if (existingClientBtn) existingClientBtn.remove();

  if (clientWALink) {
    const clientBtn = document.createElement('a');
    clientBtn.id = 'waClientBtn';
    clientBtn.className = 'wa-btn';
    clientBtn.href = clientWALink;
    clientBtn.target = '_blank';
    clientBtn.style.marginTop = '10px';
    clientBtn.style.background = '#128C7E';
    clientBtn.innerHTML = '💬 Enviar Confirmação ao Cliente';
    waBtn.parentNode.insertBefore(clientBtn, waBtn.nextSibling);
  }

  showToast('🎉 Agendamento confirmado! Código: ' + code);

  // Auto-abre WhatsApp do barbeiro após 1.2s
  setTimeout(() => {
    window.open(barberWALink, '_blank');
  }, 1200);
}

// ══════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════
function showDashboard() {
  openPinModal();
}

async function openDashboard() {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('progressBar').style.display = 'none';
  document.getElementById('dashboard').classList.add('active');
  await loadBookings();
  renderDashboard();
}

function hideDashboard() {
  document.getElementById('dashboard').classList.remove('active');
  document.getElementById('progressBar').style.display = 'flex';
  document.getElementById('screen' + state.currentScreen).classList.add('active');
}

function renderDashboard() {
  const today = new Date();
  const todayKey = today.toDateString();
  const todayStr = today.toLocaleDateString('pt-BR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
  document.getElementById('dashDate').textContent = todayStr;
  document.getElementById('dashDateFull').textContent = todayStr;

  const todayBookings = bookings.filter(b => b.dateKey === todayKey)
    .sort((a,b) => a.time.localeCompare(b.time));
  const done = todayBookings.filter(b => b.done).length;
  const pending = todayBookings.filter(b => !b.done).length;

  document.getElementById('statTotal').textContent = todayBookings.length;
  document.getElementById('statDone').textContent = done;
  document.getElementById('statPending').textContent = pending;

  const list = document.getElementById('agendaList');
  const title = list.querySelector('.agenda-title');

  // Remove old cards
  list.querySelectorAll('.agenda-card').forEach(c => c.remove());

  if (todayBookings.length === 0) {
    list.innerHTML += '<div style="color:var(--gray);text-align:center;padding:40px 20px;font-size:14px;">Nenhum agendamento para hoje ainda.</div>';
    return;
  }

  todayBookings.forEach((b, i) => {
    const card = document.createElement('div');
    card.className = 'agenda-card' + (b.done ? ' done' : '');
    card.id = 'acard_' + i;
    card.innerHTML = `
      <div class="agenda-time">${b.time}</div>
      <div class="agenda-info">
        <div class="agenda-client">${b.emoji} ${b.name}</div>
        <div class="agenda-service">${b.service} · ${b.duration} min · ${b.price}</div>
        ${b.style !== 'Não informado' ? `<div class="agenda-service">🎨 ${b.style}</div>` : ''}
        <div class="agenda-phone">📱 ${b.phone}</div>
        ${b.obs ? `<div class="agenda-service" style="color:var(--gold-dark)">📝 ${b.obs}</div>` : ''}
      </div>
      ${!b.done ? `<button class="agenda-action" onclick="markDone('${b.code}')">✓ Feito</button>` : '<span style="font-size:11px;color:var(--green)">✓ Feito</span>'}
    `;
    list.appendChild(card);
  });
}

async function markDone(code) {
  const idx = bookings.findIndex(b => b.code === code);
  if (idx >= 0) {
    bookings[idx].done = true;
    try {
      await markDoneSupabase(code);
    } catch(e) {
      console.error('Erro ao atualizar Supabase:', e);
    }
    renderDashboard();
    showToast('✅ Atendimento marcado como concluído!');
  }
}

// ══════════════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════════════
function resetApp() {
  state = {
    selectedService: null, selectedDate: null, selectedTime: null,
    selectedStyle: null, clientName: '', clientPhone: '', clientObs: '',
    currentScreen: 1, calYear: new Date().getFullYear(), calMonth: new Date().getMonth(),
  };
  document.getElementById('clientName').value = '';
  document.getElementById('clientPhone').value = '';
  document.getElementById('clientObs').value = '';
  document.getElementById('slotsSection').style.display = 'none';
  document.getElementById('btnNext1').disabled = true;
  document.getElementById('btnNext2').disabled = true;
  document.getElementById('btnNext3').disabled = true;
  document.getElementById('progressBar').style.display = 'flex';
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('dashboard').classList.remove('active');
  document.getElementById('screen1').classList.add('active');
  ['prog1','prog2','prog3','prog4'].forEach((id,i) => {
    document.getElementById(id).classList.remove('active','done');
    if (i === 0) document.getElementById(id).classList.add('active');
  });
  renderServices('all');
  renderCalendar();
  renderStyles();
  document.querySelectorAll('.cat-tab').forEach((t,i) => { t.classList.remove('active'); if(i===0) t.classList.add('active'); });
  window.scrollTo({ top: 0 });
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// Auto-init if already past splash
renderCalendar();
</script>
</body>
</html>
